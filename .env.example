# HTTP listen port (default 8090). Prefer CAT_RESCUE_HTTP_PORT—Spring Boot's SERVER_PORT is ignored by HttpPortConfiguration.
CAT_RESCUE_HTTP_PORT=8090

# ---------- MySQL（持久化库 + 存评估上传照片）----------
# 不要使用 profile「local」启动（local = 内存 H2，重启丢库）。
# 示例：export MYSQL_PASSWORD=... OPENAI_API_KEY=... 后执行：mvn spring-boot:run
# 照片：`POST /api/v1/assessments` 默认写入表 assessments（见 ASSESSMENT_PERSIST_IMAGES）。
# 取图：`GET /api/v1/assessments/{id}/image`；响应 JSON 里 imagePersisted=true 表示已存。
# 大图若写入失败，可在 MySQL 配置里增大 max_allowed_packet（如 32M）。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cat_rescue
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_mysql_password

# 是否把评估上传的图片二进制存入 MySQL（默认 true）。
ASSESSMENT_PERSIST_IMAGES=true

# ---------- 多模态评估（默认只用 OpenAI）----------
# 填写下面密钥后，启动日志应出现：Using OpenAI model: ...
# 未设置时会退化为 StubMultimodalClient（本地假数据，不是真模型）。
#
# Copy to ".env", fill OPENAI_API_KEY, then before "mvn spring-boot:run":
#   set -a && source .env && set +a
MULTIMODAL_PROVIDER=openai
OPENAI_API_KEY=replace_with_openai_key
# Optional: proxy / mirror base URL（默认 https://api.openai.com）
# OPENAI_BASE_URL=https://api.openai.com
# Optional model override（默认 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini
# Alternative env name（与 OPENAI_API_KEY 二选一即可）
# CAT_RESCUE_OPENAI_API_KEY=

TRACKING_MOCK_FEATURE_EXTRACTION=false

# Optional temporary share gate
CAT_RESCUE_SHARE_ENABLED=true
CAT_RESCUE_SHARE_PASSWORD=replace_with_share_password
CAT_RESCUE_SHARE_COOKIE_NAME=cat_rescue_share_auth

# ---------- 机构 / B2B 合作伙伴 API ----------
# 机构门户令牌格式：publicId.secret（审批通过后一次性返回完整令牌；仅保存哈希）。
# 请求头：Authorization: Bearer <token> 或 X-Institution-Token: <token>
CAT_RESCUE_INSTITUTION_TOKEN_PEPPER=replace_with_long_random_pepper
# 运营后台审核机构申请：GET/POST /api/v1/institution/admin/** 需携带请求头
# X-Cat-Rescue-Institution-Admin: <与下方相同的值>
CAT_RESCUE_INSTITUTION_ADMIN_TOKEN=replace_with_admin_secret

# Optional: full site URL for volunteer share links (no trailing slash). Leave empty when UI and API share the same origin.
# PUBLIC_BASE_URL=https://your-site.example.com
